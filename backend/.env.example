NODE_ENV=development
PORT=5050
CLIENT_ORIGIN=http://localhost:3000
# Admin console origin (CORS)
ADMIN_ORIGIN=http://localhost:3001
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=

# Solana / TxLINE World Cup settlement
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# base58-encoded keeper secret key (protocol signer for init_market / settle)
SOLANA_KEEPER_PRIVATE_KEY=
# SPL USDC mint used for stakes/pools on the target cluster
SOLANA_USDC_MINT=
# TxLINE data API
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# X-Api-Token from the subscribe + /api/token/activate flow (World Cup devnet tier)
TXLINE_API_TOKEN=

# Circle WaaS (Solana wallets) & Resend Configuration
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
# Circle Solana blockchain id: SOL-DEVNET (devnet) or SOL (mainnet)
CIRCLE_SOLANA_BLOCKCHAIN=SOL-DEVNET
RESEND_API_KEY=
RESEND_FROM_EMAIL=
